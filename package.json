{
  "name": "@hdanyal/paperclip-plugin-agentmail",
  "version": "1.0.0",
  "description": "AgentMail → Paperclip: webhooks create issues with attachments; inbox-scoped REST tools. Independent third-party plugin (not tied to any employer org).",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "hdanyal",
  "repository": {
    "type": "git",
    "url": "https://github.com/hdanyal/paperclip-plugin-agentmail.git"
  },
  "bugs": {
    "url": "https://github.com/hdanyal/paperclip-plugin-agentmail/issues"
  },
  "homepage": "https://github.com/hdanyal/paperclip-plugin-agentmail#readme",
  "keywords": [
    "paperclip",
    "plugin",
    "agentmail",
    "email",
    "third-party"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "scripts/install-dev-to-paperclip.mjs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "STANDALONE.md",
    "docs"
  ],
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "prebuild": "node ./scripts/ensure-sdk.mjs",
    "build": "tsc && node ./scripts/build-ui.mjs",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pack:check": "npm pack --dry-run --ignore-scripts",
    "prepack": "npm run build",
    "verify": "npm run typecheck && npm run test && npm run build && npm run pack:check",
    "release:check": "npm run verify",
    "paperclip:dev-sync": "node ./scripts/install-dev-to-paperclip.mjs",
    "paperclip:dev-sync:build": "node ./scripts/install-dev-to-paperclip.mjs --build"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "2026.427.0",
    "html-to-text": "^9.0.5",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.1",
    "svix": "^1.59.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
